#!/bin/bash

alias gbr='git branch'
alias gco='git checkout'
alias gdf='git diff'
alias glg='git log -p'
alias glol='git log --graph --decorate --pretty=oneline --abrev-commit'
alias glola='git log --graph --decorate --pretty=oneline --abrev-commit --all'
alias gll='git log --pretty=oneline --abbrev-commit --max-count=15'
alias greview='git log -p --max-count=1'
alias gwip='git add -u && git commit -m ...'
alias gwipc='!date >> WIP && git add WIP && git commit -m ...'
alias gfp='git format-patch --stdout'
alias gci='git commit'
alias gx='git checkout HEAD'
alias gst='git status'
alias gamend='git-amend'
alias gall='git-all'
alias gcv='git-cv'
alias gcredit='git-credit'
alias gdropbox='git-dropbox'
alias grank='git-rank-contributors'
alias greup='git-reup'
alias gthanks='git-thanks'
alias gup='git-up'
alias gundo='git-undo'
alias gwtf='git-wtf'

alias glog="git log --graph --pretty=format:'%Cred%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative"
alias gpu='git push origin HEAD'
alias gp='git push'
alias gb='git branch'
alias gssb='git status -sb'
alias grm="git status | grep deleted | awk '{print \$3}' | xargs git rm"

alias ga='git add'
alias gb='git branch'
alias gc='git checkout'
alias gd='git diff'
alias gf='git fetch --prune'
alias gk='git cherry-pick'
alias gl='git log --pretty=oneline --abbrev-commit'
alias gn='git commit --verbose --amend'
alias gr='git remote'
alias gs='git status'
alias gt='git diff --cached'
alias gdc='git diff --cached'
alias gaa='git add --update'
alias gap='git add --patch'
alias gdcs='gitgdiff --cached --stat'
alias gunstage='git reset HEAD'
alias gci='git commit --verbose'
alias gca='git commit --verbose --all'
alias gcm='git commit -m'
alias gre='git rebase --interactive'
alias gpop='git reset --soft HEAD^'
alias gpeek='git log -p --max-count=1'
alias gf='git fetch'
alias gpm='git pull'
alias gpr='git pull --rebase'
alias gd='git diff'
alias gds='git diff --stat'
alias ghard='git reset --hard'
alias gsoft='git reset --soft'
alias gscrap='git checkout HEAD'
