"slock"
  control + alt + l

"sleep 1; xset dpms force off"
  control + alt + d

"urxvt -e screen -D -R"
  control + alt + Return

"dmenu_run -fn 'Terminus-9'  -nb '#555753' -nf '#D3D7DF' -sb '#2E3436' -sf '#EEEEEC'"
  control + alt + space

"amixer set Master 10%+"
  XF86AudioRaiseVolume

"amixer set Master 10%-"
  XF86AudioLowerVolume

"amixer set Master toggle"
  XF86AudioMute

"xbacklight -inc 25"
  XF86MonBrightnessUp

"xbacklight -dec 10"
  XF86MonBrightnessDown

"scrot"
  Print

"mpc toggle"
  control + alt + t

"mpc stop"
  control + alt + s

"mpdmenu"
  control + alt + m

"mpc volume +10"
  control + alt + plus

"mpc volume -10"
  control + alt + minus

"mpc next"
  control + alt + period

"mpc prev"
  control + alt + comma

"songgood"
  control + alt + y

"songgood -p"
  control + alt + u
