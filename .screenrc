# ~/.screenrc

startup_message off
defscrollback 30000
autodetach on
defutf8 on

bell_msg '^G'
altscreen on
defbce on
defflow off
nonblock on
msgwait 0
vbell off

attrcolor b ".I"
deflogin on
defutf8 on
activity "active: %n (%t) [%w:%s]"
defhstatus "screen: ^En (^Et)"
terminfo rxvt* 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'

#hardstatus always message '%{= k}.%{= 0} %= %{= w}%-w%{+b r}%n*%t%{-b r}%{w}%+w %= %{k}.'
#caption always "%{= kb}[ %{kB}$USER@%H %{b}][ %=%{w}%?%-Lw%?%{b}(%{W}%n*%f %t%?(%u)%?%{b})%{w}%?%+Lw%?%= %{b}][%{kB} %d.%m.%Y %{kW}%0c %{kb}]"
hardstatus on
hardstatus message 'screen: %-Lw(%n*%f %t)%+Lw'

screen -t kernel 1 bash
screen -t gdb 2 bash
select 1

# keybinding

#escape

bind ^k
bind ^\
bind W
bind k
bind .
bind \\
bind ^h
bind h

bind Q quit
bind W windowlist
bind K kill
bind } history

bindkey "^[Od" prev  # change window with ctrl-left
bindkey "^[Oc" next  # change window with ctrl-right

# find the nearest shell
bind s select bash

# make scroll work
termcapinfo rxvt-unicode ti@:te@
# make colors work
termcapinfo rxvt-unicode 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'
