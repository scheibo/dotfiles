#!/bin/bash

dircolors="$(type -P gdircolors dircolors | head -1)"
test -n "$dircolors" && {
    COLORS=/etc/DIR_COLORS
    test -e "/etc/DIR_COLORS.$TERM"   && COLORS="/etc/DIR_COLORS.$TERM"
    test -e "$HOME/.dircolors"        && COLORS="$HOME/.dircolors"
    test ! -e "$COLORS"               && COLORS=
    eval `$dircolors --sh $COLORS`
}
unset dircolors

push_ssh_cert() {
    local _host
    test -f ~/.ssh/id_rsa.pub || ssh-keygen -t rsa
    for _host in "$@";
    do
        echo $_host
        ssh $_host 'cat >> ~/.ssh/authorized_keys' < ~/.ssh/id_rsa.pub
    done
}

extract() {
     if [ -f $1 ] ; then
         case $1 in
             *.tar.bz2)   tar xvjf $1     ;;
             *.tar.gz)    tar xvzf $1     ;;
             *.bz2)       bunzip2 $1      ;;
             *.rar)       unrar x $1      ;;
             *.gz)        gunzip $1       ;;
             *.tar)       tar xvf $1      ;;
             *.tbz2)      tar xvjf $1     ;;
             *.tgz)       tar xvzf $1     ;;
             *.zip)       unzip $1        ;;
             *.Z)         uncompress $1   ;;
             *.7z)        7z x $1         ;;
             *)           echo "'$1' cannot be extracted via >extract<" ;;
         esac
     else
         echo "'$1' is not a valid file"
     fi
}

# GPG helpers
encrypt() { gpg -ao cipher.asc -esr $2 $1; }
decrypt() { gpg -o plain.txt -d $1; }

# Traversal tools
cdir() { mkdir $1 && cd $1; }
cpf() { cp "$@" && goto "$_"; }
mvf() { mv "$@" && goto "$_"; }

# enable color support of ls and also add handy aliases
if [ -x /bin/dircolors ]; then
#   eval "`dircolors -b`"
    alias ls='ls --color=auto'
    alias dir='dir --color=auto'
    alias vdir='vdir --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

LS_COMMON="-hBG"
test -n "$LS_COMMON" &&
alias ls="command ls $LS_COMMON"

# `ls` conveniences
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'
alias lal='ls -l -A'
alias lla='ls -l -A'
alias lsl='ls -l'
alias lsa='ls -A'

# `cd` conveniences
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
alias dc='cd -'

# Typos
alias xs='cd'
alias vf='cd'
alias cs='cd'
alias cd..='cd ..'
alias unmount='umount'
alias LS='ls'
alias sl='ls'

# Short forms
alias h='history'
alias c='clear'
alias g='git'

# Miscellaneous
alias vim="vim -O"
alias vi='command vim'
alias tmux="TERM=screen-256color-bce tmux"
alias root='cd $(git rev-parse --show-toplevel)'
alias wget='wget --no-check-certificate'
alias sbashrc='source ~/.bashrc'
alias ps2pdf='ps2pdf -sPAPERSIZE=a4 -dOptimize=true -dEmbedAllFonts=true'
alias irb='irb --prompt simple'
alias mkdir='mkdir -p'
alias hc='history -c'
alias gcc99='gcc -std=c99 -O -Wall'
alias crun='valgrind --leak-check=yes ./a.out'
